{
	"compilerOptions": {
		"target": "ESNext", // ECMAScript 버전
		"useDefineForClassFields": true, // 클래스 필드에 대한 모듈 정의 사용 여부
		"lib": ["DOM", "DOM.Iterable", "ESNext"], // 사용할 라이브러리
		"allowJs": true, // JavaScript 파일 사용 여부
		"skipLibCheck": true, // 라이브러리 체크 skip 여부
		"esModuleInterop": true, // 모듈식 ES6+ 코드에서 객체 전개 구문을 사용 여부
		"allowSyntheticDefaultImports": true, // 모듈에서 default 값을 가진 임포트 구문 사용 여부
		"experimentalDecorators": true, // decorator 사용 여부
		"strict": true, // strict mode 사용 여부
		"forceConsistentCasingInFileNames": true, // 파일과 모듈 이름의 대소문자를 일관되게 유지
		"module": "ESNext", // 모듈 시스템
		"moduleResolution": "Node", // 모듈을 로드하는 방법
		"resolveJsonModule": true, // JSON 모듈을 사용 여부
		"isolatedModules": true, // 모듈을 격리하여 다른 모듈과 충돌을 방지
		"noEmit": true, // 컴파일된 JavaScript 파일을 생성
		"strictNullChecks": false, // null 체크를 엄격하게 적용
		"jsx": "react-jsx", // JSX 구문을 처리하는 방법
		"baseUrl": ".", // 기준 경로
		"paths": {
			"@/publish/*": ["src/publish/*"],
			"@/*": ["src/*"]
		}
	},
	"include": ["src", "auto.d.ts", "custom.d.ts", "src/jest.config.ts"], // 컴파일 대상 파일 경로
	"references": [
		// 참조하는 tsconfig.json 파일 경로
		{
			"path": "./tsconfig.node.json"
		}
	],
	// 자동으로 사용 가능한 import를 제안
	"typescript.suggest.autoImports": true,
	"javascript.suggest.autoImports": true,

	// 저장 시 사용하지 않는 import 제거
	"editor.codeActionsOnSave": {
		"source.organizeImports": true
	},

	// 저장 시 코드 자동 포맷
	"editor.formatOnSave": true
}
